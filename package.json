{
  "name": "gecktrack",
  "version": "0.0.1",
  "description": "A local music player with a geck!",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.gecktrack",
    "productName": "GeckTrack",
    "directories": {
      "output": "release/"
    },
    "win": {
      "target": "nsis"
    },
    "extraResources": [
      {
        "from": "data",
        "to": "data"
      },
      {
        "from": "backend",
        "to": "backend"
      }
    ]
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  }
}
